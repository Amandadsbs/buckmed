rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isGroupMember(groupId) {
      return isAuthenticated() && (groupId in userDoc().groups);
    }

    function isGroupAdmin(groupId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/care_groups/$(groupId)).data.admin_id == request.auth.uid;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Care Groups ────────────────────────────────────────────────────────
    match /care_groups/{groupId} {
      allow read: if isGroupMember(groupId);
      allow create: if isAuthenticated() && request.resource.data.admin_id == request.auth.uid;

      // Admin can update anything; OR any authenticated user can only add
      // themselves to the members array (for invite acceptance)
      allow update: if isGroupAdmin(groupId) ||
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.auth.uid in request.resource.data.members &&
          !(request.auth.uid in resource.data.members));

      allow delete: if isGroupAdmin(groupId);
    }

    // ── Patients ───────────────────────────────────────────────────────────
    match /patients/{patientId} {
      allow read, update, delete: if isGroupMember(resource.data.group_id);
      allow create: if isGroupMember(request.resource.data.group_id);
    }

    // ── Medications ────────────────────────────────────────────────────────
    match /medications/{medId} {
      allow read, update, delete: if isGroupMember(resource.data.group_id);
      allow create: if isGroupMember(request.resource.data.group_id);
    }

    // ── Medication Logs ────────────────────────────────────────────────────
    match /medication_logs/{logId} {
      allow read, update, delete: if isGroupMember(resource.data.group_id);
      allow create: if isGroupMember(request.resource.data.group_id);
    }

    // ── Group Invites (link-based) ─────────────────────────────────────────
    match /group_invites/{inviteId} {
      allow get: if isAuthenticated();
      allow list: if isGroupAdmin(resource.data.group_id);
      allow create: if isGroupAdmin(request.resource.data.group_id);
      allow update: if isAuthenticated();
      allow delete: if isGroupAdmin(resource.data.group_id);
    }

    // ── Pending Invites (email-based) ──────────────────────────────────────
    // Admin creates them; the invited user can read their own (by email match)
    // and update (to mark accepted). AuthProvider handles acceptance server-side via admin SDK.
    match /pending_invites/{inviteId} {
      // Admin of the group can read, create, update, delete
      allow read, create, update, delete: if isGroupAdmin(resource.data.group_id) ||
        isGroupAdmin(request.resource.data.group_id);

      // Invited user can read their own invite by email
      allow read: if isAuthenticated() && resource.data.email == request.auth.token.email;

      // Any authenticated user can query pending_invites by email
      // (needed for AuthProvider's checkAndAcceptPendingInvite)
      allow list: if isAuthenticated();

      // Invited user can update their own invite (mark as accepted)
      allow update: if isAuthenticated() && resource.data.email == request.auth.token.email;
    }

    // ── FCM Tokens ─────────────────────────────────────────────────────────
    match /fcm_tokens/{tokenId} {
      allow read, delete: if isAuthenticated() && request.auth.uid == resource.data.caregiver_id;
      allow create, update: if isAuthenticated() && request.resource.data.caregiver_id == request.auth.uid;
    }
  }
}
