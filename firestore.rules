rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGroupAdmin(groupId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/care_groups/$(groupId)).data.admin_id == request.auth.uid;
    }

    function isGroupMember(groupId) {
      let uData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && groupId != null && (
        (uData.keys().hasAll(['groups']) && groupId in uData.groups) ||
        (uData.keys().hasAll(['active_group']) && groupId == uData.active_group)
      );
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Care Groups ────────────────────────────────────────────────────────
    match /care_groups/{groupId} {
      allow read: if isGroupMember(groupId) || (isAuthenticated() && request.auth.uid in resource.data.members);
      allow create: if isAuthenticated() && request.resource.data.admin_id == request.auth.uid;

      // Admin can update anything; OR any authenticated user can only add
      // themselves to the members array (for invite acceptance)
      allow update: if isGroupAdmin(groupId) ||
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.auth.uid in request.resource.data.members);

      allow delete: if isGroupAdmin(groupId);
    }

    // ── Patients ───────────────────────────────────────────────────────────
    match /patients/{patientId} {
      allow read, update, delete: if isGroupMember(resource.data.get('group_id', ''));
      allow create: if isGroupMember(request.resource.data.get('group_id', ''));
    }

    // ── Medications ────────────────────────────────────────────────────────
    match /medications/{medId} {
      allow read, update, delete: if isGroupMember(resource.data.get('group_id', ''));
      allow create: if isGroupMember(request.resource.data.get('group_id', ''));
    }

    // ── Medication Logs ────────────────────────────────────────────────────
    match /medication_logs/{logId} {
      allow read, update, delete: if isGroupMember(resource.data.get('group_id', ''));
      allow create: if isGroupMember(request.resource.data.get('group_id', ''));
    }

    // ── Group Invites (link-based) ─────────────────────────────────────────
    match /group_invites/{inviteId} {
      allow get: if isAuthenticated();
      allow list: if isGroupAdmin(resource.data.group_id);
      allow create: if isGroupAdmin(request.resource.data.group_id);
      allow update: if isAuthenticated();
      allow delete: if isGroupAdmin(resource.data.group_id);
    }

    // ── Pending Invites (email-based) ──────────────────────────────────────
    match /pending_invites/{inviteId} {
      allow read, delete: if isGroupAdmin(resource.data.group_id) || 
        (isAuthenticated() && request.auth.token.email != null && resource.data.email == request.auth.token.email);
        
      allow create: if isGroupAdmin(request.resource.data.group_id);
      
      // Admin can update, OR invited user can update their own invite
      allow update: if isGroupAdmin(resource.data.group_id) ||
        (isAuthenticated() && request.auth.token.email != null && resource.data.email == request.auth.token.email);
        
      allow list: if isAuthenticated();
    }

    // ── FCM Tokens ─────────────────────────────────────────────────────────
    match /fcm_tokens/{tokenId} {
      allow read, delete: if isAuthenticated() && request.auth.uid == resource.data.caregiver_id;
      allow create, update: if isAuthenticated() && request.resource.data.caregiver_id == request.auth.uid;
    }
  }
}
